rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Student Validation
    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'course', 'gpa', 'priority', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.course is string && data.course.size() > 0 && data.course.size() <= 100 &&
             data.gpa is number && data.gpa >= 0 && data.gpa <= 10.0 &&
             data.priority is number && data.priority >= 0 &&
             data.createdAt == request.time;
    }

    // Exam Validation
    function isValidExam(data) {
      return data.keys().hasAll(['subject', 'date', 'room', 'priority', 'createdAt']) &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 100 &&
             data.date is string && data.date.size() > 0 &&
             data.room is string && data.room.size() > 0 && data.room.size() <= 50 &&
             data.priority is number && data.priority >= 1 && data.priority <= 10 &&
             data.createdAt == request.time;
    }

    match /students/{studentId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && isValidStudent(incoming());
      allow update: if isSignedIn() && isValidStudent(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'course', 'gpa', 'priority'])
      );
      allow delete: if isSignedIn();
    }

    match /exams/{examId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && isValidExam(incoming());
      allow update: if isSignedIn() && isValidExam(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['subject', 'date', 'room', 'priority'])
      );
      allow delete: if isSignedIn();
    }

    // System health check
    match /system/{docId} {
      allow get: if true;
    }
  }
}
