{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student record in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Student unique ID" },
        "name": { "type": "string", "description": "Full name of the student" },
        "course": { "type": "string", "description": "Enrolled course" },
        "gpa": { "type": "number", "description": "Current GPA" },
        "priority": { "type": "number", "description": "Calculated priority for various administrative tasks" }
      },
      "required": ["id", "name", "course", "gpa"]
    },
    "Exam": {
      "title": "Exam",
      "description": "An exam schedule record.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Exam unique ID" },
        "subject": { "type": "string", "description": "Subject name" },
        "date": { "type": "string", "format": "date-time", "description": "Scheduled date and time" },
        "room": { "type": "string", "description": "Assigned room" },
        "priority": { "type": "number", "description": "Urgency priority (1-10)" }
      },
      "required": ["id", "subject", "date", "room", "priority"]
    }
  },
  "firestore": {
    "students": {
      "schema": "Student",
      "description": "Collection of student records"
    },
    "exams": {
      "schema": "Exam",
      "description": "Collection of scheduled exams"
    }
  }
}
